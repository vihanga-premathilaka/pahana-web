<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Pahana Edu</display-name>

    <!-- Add Customer -->
    <servlet>
        <servlet-name>AddCustomerServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.AddCustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCustomerServlet</servlet-name>
        <url-pattern>/addCustomer</url-pattern>
    </servlet-mapping>

    <!-- Edit Customer -->
    <servlet>
        <servlet-name>EditCustomerServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.EditCustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EditCustomerServlet</servlet-name>
        <url-pattern>/editCustomer</url-pattern>
    </servlet-mapping>

    <!-- Delete Customer -->
    <servlet>
        <servlet-name>DeleteCustomerServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.EditCustomerServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteCustomerServlet</servlet-name>
        <url-pattern>/deleteCustomer</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ItemServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.ItemServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ItemServlet</servlet-name>
        <url-pattern>/items</url-pattern>
    </servlet-mapping>

    <!-- Billing: one servlet (create, confirm, print) -->
    <servlet>
        <servlet-name>BillingServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.BillingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BillingServlet</servlet-name>
        <url-pattern>/billing</url-pattern>
    </servlet-mapping>


    <!-- Customer Details -->
    <servlet>
        <servlet-name>CustomerDetailsServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.CustomerDetailsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerDetailsServlet</servlet-name>
        <url-pattern>/customerDetails</url-pattern>
    </servlet-mapping>


    <!-- Help Section -->
    <servlet>
        <servlet-name>HelpServlet</servlet-name>
        <servlet-class>lk.youruni.pahana.web.HelpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HelpServlet</servlet-name>
        <url-pattern>/help</url-pattern>
    </servlet-mapping>



    <!-- Optional: default welcome -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
